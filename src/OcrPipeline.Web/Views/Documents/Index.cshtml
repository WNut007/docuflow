@model IReadOnlyList<Document>
@{
    ViewData["Title"] = "Documents";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Documents</h1>
    <a class="btn btn-primary" asp-action="Upload"><i class="bi bi-upload"></i> Upload document</a>
</div>

@* Pipeline stage strip *@
<div class="card mb-4">
    <div class="card-body py-3">
        <div class="d-flex flex-wrap align-items-center gap-2 small text-body-secondary">
            <span class="badge text-bg-secondary"><i class="bi bi-inbox"></i> Capture</span>
            <i class="bi bi-chevron-right"></i>
            <span class="badge text-bg-info"><i class="bi bi-tag"></i> Classify</span>
            <i class="bi bi-chevron-right"></i>
            <span class="badge text-bg-primary"><i class="bi bi-file-text"></i> Extract (OCR)</span>
            <i class="bi bi-chevron-right"></i>
            <span class="badge text-bg-primary"><i class="bi bi-link-45deg"></i> Enrich</span>
            <i class="bi bi-chevron-right"></i>
            <span class="badge text-bg-success"><i class="bi bi-check2-circle"></i> Validate</span>
            <i class="bi bi-chevron-right"></i>
            <span class="badge text-bg-success"><i class="bi bi-diagram-3"></i> Map</span>
            <i class="bi bi-chevron-right"></i>
            <span class="badge text-bg-dark"><i class="bi bi-send"></i> Consume</span>
        </div>
    </div>
</div>

<div class="small text-body-secondary mb-2">
    Queue status (the <strong>Status</strong> column):
    <span class="badge text-bg-secondary">CAPTURED</span> queued ·
    <span class="badge text-bg-info">CLASSIFIED</span>/<span class="badge text-bg-primary">EXTRACTED</span> processing ·
    <span class="badge text-bg-success">MAPPED</span>/<span class="badge text-bg-warning">NEEDS_REVIEW</span>/<span class="badge text-bg-success">VALIDATED</span> done ·
    <span class="badge text-bg-danger">FAILED</span> failed
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th><th>File</th><th>Source</th><th>Status</th>
                    <th>Pages</th><th>Uploaded (UTC)</th><th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-body-secondary py-4">No documents yet.</td></tr>
            }
            @foreach (var d in Model)
            {
                <tr>
                    <td class="text-body-secondary">@d.DocumentId</td>
                    <td><i class="bi bi-file-earmark"></i> @d.OriginalFileName</td>
                    <td><span class="badge text-bg-light">@d.SourceChannel</span></td>
                    <td>@await Html.PartialAsync("_StatusBadge", d.StatusCode)</td>
                    <td>@d.PageCount</td>
                    <td class="small text-body-secondary">@d.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Detail" asp-route-id="@d.DocumentId">
                            View <i class="bi bi-arrow-right"></i>
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
