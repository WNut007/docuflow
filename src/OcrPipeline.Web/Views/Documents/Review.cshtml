@model ReviewViewModel
@{
    ViewData["Title"] = "Review";
    var data = new
    {
        documentId = Model.Document.DocumentId,
        pageCount = Model.PageCount,
        values = Model.Values,
        pageTableZones = Model.PageTableZones
    };
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="h4 mb-1"><i class="bi bi-clipboard-check text-body-secondary"></i> @Model.Document.OriginalFileName</h1>
        <div class="d-flex align-items-center gap-2">
            <partial name="_StatusBadge" model="@Model.Document.StatusCode" />
            @if (Model.HasResult && Model.OverallConfidence is { } oc)
            {
                <span class="badge rounded-pill text-bg-light border" title="overall confidence">
                    <i class="bi bi-speedometer2"></i> @oc.ToString("P0") confidence
                </span>
            }
        </div>
    </div>
    <a class="btn btn-sm btn-outline-secondary" asp-action="Detail" asp-route-id="@Model.Document.DocumentId">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</div>

@if (!Model.HasResult)
{
    <div class="card">
        <div class="card-body text-center text-body-secondary py-5">
            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
            This document hasn't been mapped yet — there's nothing to review.
            <div class="mt-3">
                <a class="btn btn-sm btn-outline-primary" asp-action="Detail" asp-route-id="@Model.Document.DocumentId">
                    Go to document
                </a>
            </div>
        </div>
    </div>
    return;
}

@Html.AntiForgeryToken()

<div class="row g-3 doc-pane-row">
    @* LEFT: page image with mapped values overlaid on their source boxes, coloured by confidence *@
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-text"></i> <span id="pageLabel">Page 1 / @Model.PageCount</span>
                <span class="ms-auto small text-body-secondary">
                    <span class="badge text-bg-success">high</span>
                    <span class="badge text-bg-warning">medium</span>
                    <span class="badge text-bg-danger">low</span>
                    (cutoff @Model.Cutoff.ToString("P0"))
                </span>
            </div>
            <div class="card-body p-2">
                <div class="vm-zoombar mb-2" role="toolbar" aria-label="Document toolbar">
                    @if (Model.PageCount > 1)
                    {
                        @* Page nav (multi-page only): prev/next + editable page number, all driven through showPage(). *@
                        <div class="vm-pagenav d-flex align-items-center gap-1" aria-label="Page navigation">
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="prevPage" title="Previous page" aria-label="Previous page">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <span class="d-inline-flex align-items-center gap-1 small">
                                <input type="number" class="form-control form-control-sm vm-page-input" id="pageInput"
                                       value="1" min="1" max="@Model.PageCount" aria-label="Page number" />
                                <span class="text-body-secondary">/ @Model.PageCount</span>
                            </span>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="nextPage" title="Next page" aria-label="Next page">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                        <span class="vm-divider" aria-hidden="true"></span>
                    }
                    <div class="btn-group btn-group-sm" role="group" aria-label="Zoom">
                        <button type="button" class="btn btn-outline-secondary" id="zoomOut" title="Zoom out" aria-label="Zoom out">
                            <i class="bi bi-dash-lg"></i>
                        </button>
                        <span class="btn btn-outline-secondary disabled vm-zoom-pct" id="zoomPct" aria-live="polite">100%</span>
                        <button type="button" class="btn btn-outline-secondary" id="zoomIn" title="Zoom in" aria-label="Zoom in">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="zoomFit" title="Fit to width">
                        <i class="bi bi-arrows-angle-contract"></i> Fit width
                    </button>
                </div>
                <div id="stageViewport" class="stage-viewport">
                    <div id="stage" class="visual-stage review-stage">
                        <img id="pageImg" alt="page" />
                        <div id="overlay" class="visual-overlay"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* RIGHT: editable mapped values, tinted by confidence band *@
    <div class="col-lg-5">
        <div class="card doc-scroll-card">
            <div class="card-header">Mapped values <span class="text-body-secondary small">— correct any value, then Save</span></div>
            <div class="card-body" id="valueList">
                @foreach (var v in Model.Values)
                {
                    <div class="vm-review-row border-start border-4 border-@v.BandClass mb-2">
                        <label class="form-label small mb-1 d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">@v.TargetProperty</span>
                            <span class="badge rounded-pill text-bg-@v.BandClass">@(v.Confidence is { } c ? c.ToString("P0") : "—")</span>
                        </label>
                        @if (v.Table is { } tbl)
                        {
                            @* ONE continuous editable line_item table (multi-page rows concatenated). *@
                            <div class="li-wrap" data-rvid="@v.ResultValueId" data-fieldid="@v.FieldId">
                                @if (tbl.IsMultiPage)
                                {
                                    <div class="li-pagejump mb-1">
                                        @foreach (var g in tbl.PageGroups)
                                        {
                                            <button type="button" class="li-jump badge text-bg-light border" data-page="@g.Page"
                                                    title="jump to page @g.Page">P@(g.Page)·@g.Count</button>
                                        }
                                    </div>
                                }
                                <div class="li-scroll">
                                    <table class="table table-sm li-table mb-0">
                                        <thead>
                                            <tr>
                                                @if (tbl.IsMultiPage)
                                                {
                                                    <th class="small li-pgcol">Pg</th>
                                                }
                                                @foreach (var col in tbl.Columns)
                                                {
                                                    <th class="small">
                                                        @col.SubProperty@if (col.IsAnchor)
                                                        {<span class="li-anchor" title="anchor column — identifies the row">⚓</span>}
                                                    </th>
                                                }
                                                <th class="li-delcol"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int r = 0; r < tbl.Rows.Count; r++)
                                            {
                                                var pg = r < tbl.RowPages.Count ? tbl.RowPages[r] : 1;
                                                <tr class="li-row" data-row="@r" data-pg="@pg" data-rvid="@v.ResultValueId" data-fieldid="@v.FieldId">
                                                    @if (tbl.IsMultiPage)
                                                    {
                                                        <td class="li-pgcol text-body-secondary small">@pg</td>
                                                    }
                                                    @foreach (var col in tbl.Columns)
                                                    {
                                                        var cell = tbl.Rows[r].TryGetValue(col.SubProperty, out var cv) ? cv : "";
                                                        <td>
                                                            <input class="form-control form-control-sm li-cell"
                                                                   data-rvid="@v.ResultValueId" data-fieldid="@v.FieldId"
                                                                   data-row="@r" data-pg="@pg" data-sub="@col.SubProperty"
                                                                   data-dt="@col.DataType" data-anchor="@(col.IsAnchor ? "1" : "")"
                                                                   data-original="@cell" value="@cell" />
                                                        </td>
                                                    }
                                                    <td class="li-delcol">
                                                        <button type="button" class="li-del" title="delete row" aria-label="delete row">×</button>
                                                    </td>
                                                </tr>
                                            }
                                            @if (tbl.Rows.Count == 0)
                                            {
                                                <tr><td colspan="99" class="text-body-secondary small">No rows extracted.</td></tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                        else
                        {
                            <input class="form-control form-control-sm review-input"
                                   data-rvid="@v.ResultValueId" data-fieldid="@v.FieldId" data-original="@v.NormalizedValue"
                                   value="@v.NormalizedValue" />
                            @if (!string.IsNullOrEmpty(v.RawValue) && v.RawValue != v.NormalizedValue)
                            {
                                <div class="form-text">raw: @v.RawValue</div>
                            }
                        }
                    </div>
                }
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <span id="status" class="small text-body-secondary"></span>
                <button type="button" class="btn btn-primary" id="saveBtn">
                    <i class="bi bi-check2-circle"></i> Save corrections
                </button>
            </div>
        </div>
    </div>
</div>

<script id="review-data" type="application/json">@Json.Serialize(data)</script>

@section Scripts {
    <script src="~/js/overlay.js" asp-append-version="true"></script>
    <script src="~/js/doc-viewport.js" asp-append-version="true"></script>
    <script src="~/js/review.js" asp-append-version="true"></script>
}
