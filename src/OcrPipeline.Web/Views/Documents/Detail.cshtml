@model DocumentDetailViewModel
@{
    ViewData["Title"] = "Document";
    var d = Model.Document;
    var ocr = Model.Ocr;
}
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-file-earmark-text"></i> @d.OriginalFileName</h1>
        <div class="text-body-secondary small">
            #@d.DocumentId · @d.ContentType · @(d.FileSizeBytes / 1024) KB ·
            <span class="font-monospace">@d.Sha256[..12]…</span>
        </div>
    </div>
    <div>@await Html.PartialAsync("_StatusBadge", d.StatusCode)</div>
</div>

<div class="mb-3 d-flex gap-2">
    <a class="btn btn-sm btn-outline-secondary" asp-action="Index">
        <i class="bi bi-arrow-left"></i> Back to list
    </a>
    @if (d.StatusCode is "NEEDS_REVIEW" or "VALIDATED" or "MAPPED" or "CONSUMED")
    {
        <a class="btn btn-sm btn-outline-primary" asp-action="Review" asp-route-id="@d.DocumentId">
            <i class="bi bi-clipboard-check"></i> Review accuracy
        </a>
    }
</div>

@if (ocr is null)
{
    <div class="alert alert-warning"><i class="bi bi-hourglass"></i> No OCR result yet.</div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between">
                    <span><i class="bi bi-fonts"></i> Text blocks</span>
                    <span class="badge text-bg-light">@ocr.Engine</span>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var b in ocr.TextBlocks)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>
                                <span class="badge text-bg-light me-2">@b.BlockType</span>@b.Content
                            </span>
                            <span class="text-body-secondary small">@b.Confidence?.ToString("P0")</span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><i class="bi bi-table"></i> Extracted tables</div>
                <div class="card-body">
                    @if (ocr.Tables.Count == 0)
                    {
                        <p class="text-body-secondary mb-0">No tables detected.</p>
                    }
                    @foreach (var t in ocr.Tables)
                    {
                        var rows = t.Cells.GroupBy(c => c.RowIndex).OrderBy(g => g.Key);
                        <table class="table table-sm table-bordered">
                            <tbody>
                            @foreach (var row in rows)
                            {
                                <tr>
                                @foreach (var cell in row.OrderBy(c => c.ColIndex))
                                {
                                    @if (cell.IsHeader)
                                    {
                                        <th class="table-light">@cell.Content</th>
                                    }
                                    else
                                    {
                                        <td>@cell.Content</td>
                                    }
                                }
                                </tr>
                            }
                            </tbody>
                        </table>
                        <div class="text-body-secondary small">
                            @t.RowCount × @t.ColumnCount · confidence @t.Confidence?.ToString("P0")
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ---- Extracted properties (key/value) ---- *@
    @if (Model.Properties.Count > 0)
    {
        <div class="card mt-4">
            <div class="card-header"><i class="bi bi-list-columns"></i> Document properties</div>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead class="table-light"><tr><th>Key</th><th>Value</th><th>Confidence</th></tr></thead>
                    <tbody>
                    @foreach (var p in Model.Properties)
                    {
                        <tr><td class="fw-semibold">@p.Key</td><td>@p.Value</td>
                            <td class="text-body-secondary small">@p.Confidence?.ToString("P0")</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* ---- Mapping result (target model + per-field, after transformers) ---- *@
    @if (Model.MappedValues.Count > 0)
    {
        <div class="card mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-diagram-3"></i> Mapped to model</span>
                <span>
                    @if (Model.MappingNeedsReview)
                    {
                        <span class="badge text-bg-warning"><i class="bi bi-exclamation-triangle"></i> Needs review</span>
                    }
                    <span class="badge text-bg-light">confidence @Model.MappingConfidence?.ToString("P0")</span>
                </span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-lg-7">
                        <table class="table table-sm align-middle">
                            <thead class="table-light">
                                <tr><th>Target property</th><th>Raw</th><th>After transform</th><th>Conf.</th></tr>
                            </thead>
                            <tbody>
                            @foreach (var v in Model.MappedValues)
                            {
                                <tr class="@(v.IsBelowThreshold ? "table-warning" : "")">
                                    <td class="fw-semibold">@v.TargetProperty</td>
                                    <td class="text-body-secondary"><code>@v.RawValue</code></td>
                                    <td><code>@v.NormalizedValue</code></td>
                                    <td class="small">@v.Confidence?.ToString("P0")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                    <div class="col-lg-5">
                        <label class="form-label small text-body-secondary">Target model (JSON)</label>
                        <pre class="bg-body-tertiary p-3 rounded small mb-0"><code>@Model.MappedJson</code></pre>
                    </div>
                </div>
            </div>
        </div>
    }
}

@* ---- Export / Consumption ---- *@
<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-send"></i> Export</span>
        @if (d.StatusCode is "VALIDATED" or "CONSUMED")
        {
            <form asp-controller="Exports" asp-action="Reexport" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="documentId" value="@d.DocumentId" />
                <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-repeat"></i> Re-export</button>
            </form>
        }
    </div>
    <div class="card-body">
        @if (TempData["ExportMsg"] is string exportMsg)
        {
            <div class="alert alert-info py-2"><i class="bi bi-info-circle"></i> @exportMsg</div>
        }
        @if (Model.ExportLogs.Count == 0)
        {
            <p class="text-body-secondary small mb-0">
                No export attempts yet. Documents are exported automatically when they reach
                <span class="badge text-bg-success">VALIDATED</span> (for active targets).
            </p>
        }
        else
        {
            <table class="table table-sm align-middle mb-0">
                <thead class="table-light"><tr><th>When (UTC)</th><th>Target</th><th>Status</th><th>HTTP</th><th>Response</th></tr></thead>
                <tbody>
                @foreach (var l in Model.ExportLogs)
                {
                    <tr>
                        <td class="small text-body-secondary">@l.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@(l.TargetName ?? l.TargetId?.ToString() ?? "—")</td>
                        <td><span class="badge text-bg-@(l.StatusCode == "SUCCESS" ? "success" : "danger")">@l.StatusCode</span></td>
                        <td>@(l.HttpStatus?.ToString() ?? "—")</td>
                        <td class="small text-truncate" style="max-width: 360px;">@l.ResponseSnippet</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
