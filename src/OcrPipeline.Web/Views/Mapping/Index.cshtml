@model IReadOnlyList<(OcrPipeline.Web.Domain.MappingTemplate tpl, string docType, int fieldCount)>
@{ ViewData["Title"] = "Mappings"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Mapping templates</h1>
    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#newTpl">
        <i class="bi bi-plus-lg"></i> New template
    </button>
</div>
<div class="collapse mb-3" id="newTpl">
    <div class="card card-body">
        <form method="post" asp-action="CreateTemplate" enctype="multipart/form-data" class="row g-3">
            @Html.AntiForgeryToken()
            <div class="col-12">
                <label class="form-label small mb-1">Template name</label>
                <input name="name" class="form-control form-control-sm" placeholder="e.g. Invoice — Acme single page" required />
            </div>
            <div class="col-md-6">
                <label class="form-label small mb-1">Document type</label>
                <select name="documentTypeId" class="form-select form-select-sm" required>
                @foreach (var dt in (IReadOnlyList<(int Id, string Name)>)(ViewBag.DocTypes ?? new List<(int, string)>()))
                {
                    if (dt.Id == 1)
                    {
                        <option value="@dt.Id" selected>@dt.Name</option>
                    }
                    else
                    {
                        <option value="@dt.Id">@dt.Name</option>
                    }
                }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label small mb-1">Mapping mode</label>
                <select name="mappingMode" class="form-select form-select-sm">
                    <option value="ZONAL" selected>Zonal (drawn zones)</option>
                    <option value="OCR_FIRST">OCR-first (blocks)</option>
                </select>
            </div>
            <div class="col-12">
                <label class="form-label small mb-1">Sample document</label>
                <input name="sample" type="file" accept=".pdf,image/*" class="form-control form-control-sm" required />
                <div class="form-text">PDF or image to draw zones over.</div>
            </div>
            <div class="col-12 d-flex justify-content-end">
                <button class="btn btn-sm btn-primary" type="submit">
                    <i class="bi bi-vector-pen me-1"></i>Create &amp; draw zones
                </button>
            </div>
        </form>
    </div>
</div>
<p class="text-body-secondary">
    A template maps extracted <strong>document properties</strong> onto a <strong>target model</strong>'s fields,
    with an optional transformer pipeline per field.
</p>
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr><th>Template</th><th>Document type</th><th>Target model</th><th>Version</th><th>Fields</th><th></th></tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-body-secondary py-4">No templates.</td></tr>
            }
            @foreach (var (tpl, docType, fieldCount) in Model)
            {
                <tr>
                    <td class="fw-semibold">@tpl.Name</td>
                    <td><span class="badge text-bg-light">@docType</span></td>
                    <td><code>@tpl.TargetModel</code></td>
                    <td>v@tpl.Version</td>
                    <td>@fieldCount</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-success" asp-action="Visual" asp-route-templateId="@tpl.TemplateId">
                            <i class="bi bi-bounding-box-circles"></i> Map visually
                        </a>
                        <a class="btn btn-sm btn-outline-warning" asp-action="Zones" asp-route-templateId="@tpl.TemplateId">
                            <i class="bi bi-vector-pen"></i> Zones
                        </a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@tpl.TemplateId">
                            <i class="bi bi-diagram-3"></i> Edit mapping
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
