@model VisualMappingViewModel
@{
    ViewData["Title"] = "Visual mapping";
    var data = new
    {
        templateId = Model.TemplateId,
        documentId = Model.DocumentId,
        pageCount = Model.PageCount,
        fields = Model.Fields,
        documents = Model.Documents,
        templateOptions = Model.TemplateOptions
    };
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <h1 class="h4 mb-0"><i class="bi bi-bounding-box-circles"></i> Map: @Model.Name</h1>
        <div class="text-body-secondary small">Click a field, then click its box on the document to bind it.</div>
    </div>
    <a class="btn btn-sm btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Back</a>
</div>

@Html.AntiForgeryToken()

<div class="row g-3">
    @* ---------------- LEFT: page image + clickable OCR boxes ---------------- *@
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-image"></i>
                <select id="docSelect" class="form-select form-select-sm" style="max-width: 320px;">
                    @foreach (var d in Model.Documents)
                    {
                        <option value="@d.DocumentId" selected="@(d.DocumentId == Model.DocumentId)">
                            @d.FileName (@d.PageCount p.)
                        </option>
                    }
                </select>
                <div class="ms-auto btn-group btn-group-sm" id="pager" role="group">
                    <button type="button" class="btn btn-outline-secondary" id="prevPage"><i class="bi bi-chevron-left"></i></button>
                    <span class="btn btn-outline-secondary disabled" id="pageLabel">1 / @Model.PageCount</span>
                    <button type="button" class="btn btn-outline-secondary" id="nextPage"><i class="bi bi-chevron-right"></i></button>
                </div>
            </div>
            <div class="card-body p-2">
                <div id="stage" class="visual-stage">
                    <img id="pageImg" alt="page" />
                    <div id="overlay" class="visual-overlay"></div>
                </div>
                <div id="noDoc" class="text-center text-body-secondary py-5 d-none">
                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                    No previewed document of this type yet. Upload one to map visually.
                </div>
            </div>
        </div>
    </div>

    @* ---------------- RIGHT: fields, tabs, selectors ---------------- *@
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <label class="small text-body-secondary mb-0">Template</label>
                    <select id="templateSelect" class="form-select form-select-sm">
                        @foreach (var t in Model.TemplateOptions)
                        {
                            <option value="@t.TemplateId" selected="@t.IsCurrent">@t.Label</option>
                        }
                    </select>
                </div>
                <ul class="nav nav-tabs card-header-tabs" id="tabs">
                    <li class="nav-item"><a class="nav-link active" data-tab="fields" href="#">Fields</a></li>
                    <li class="nav-item"><a class="nav-link" data-tab="kv" href="#">Key-value</a></li>
                    <li class="nav-item"><a class="nav-link" data-tab="tables" href="#">Tables</a></li>
                    <li class="nav-item"><a class="nav-link" data-tab="ocr" href="#">OCR</a></li>
                </ul>
            </div>
            <div class="card-body">
                <div class="input-group input-group-sm mb-2">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input id="filter" class="form-control" placeholder="Filter…" />
                </div>

                <div id="pane-fields" class="vm-pane"></div>
                <div id="pane-kv" class="vm-pane d-none"></div>
                <div id="pane-tables" class="vm-pane d-none"></div>
                <div id="pane-ocr" class="vm-pane d-none"></div>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <button type="button" class="btn btn-sm btn-outline-primary" id="addField">
                    <i class="bi bi-plus-lg"></i> New field
                </button>
                <div class="d-flex align-items-center gap-2">
                    <span id="status" class="small text-body-secondary"></span>
                    <button type="button" class="btn btn-sm btn-primary" id="saveBtn"><i class="bi bi-save"></i> Save</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script id="vm-data" type="application/json">@Json.Serialize(data)</script>

@section Scripts {
    <script src="~/js/visual-mapping.js" asp-append-version="true"></script>
}
