@model ZoneDesignerViewModel
@{
    ViewData["Title"] = "Zone designer";
    var data = new
    {
        templateId = Model.TemplateId,
        mappingMode = Model.MappingMode,
        documentId = Model.DocumentId,
        pageCount = Model.PageCount,
        fields = Model.Fields,
        templateOptions = Model.TemplateOptions
    };
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <h1 class="h4 mb-0"><i class="bi bi-vector-pen"></i> Zones: @Model.Name</h1>
        <div class="text-body-secondary small">
            Pick a field, then drag a rectangle over its value on the document. OCR runs only inside each zone.
        </div>
    </div>
    <a class="btn btn-sm btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-left"></i> Back</a>
</div>

@Html.AntiForgeryToken()

<div class="row g-3">
    @* ---------------- LEFT: page image + draggable zones ---------------- *@
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-image"></i>
                <span class="small text-body-secondary">Sample document</span>
                <div class="ms-auto btn-group btn-group-sm" id="pager" role="group">
                    <button type="button" class="btn btn-outline-secondary" id="prevPage"><i class="bi bi-chevron-left"></i></button>
                    <span class="btn btn-outline-secondary disabled" id="pageLabel">1 / @Model.PageCount</span>
                    <button type="button" class="btn btn-outline-secondary" id="nextPage"><i class="bi bi-chevron-right"></i></button>
                </div>
            </div>
            <div class="card-body p-2">
                <div id="stage" class="visual-stage zone-stage">
                    <img id="pageImg" alt="page" />
                    <div id="overlay" class="visual-overlay"></div>
                </div>
                <div id="noDoc" class="text-center text-body-secondary py-5 d-none">
                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                    This template has no sample yet.
                    <a asp-action="Index">Create a template</a> with a sample to draw zones over.
                </div>
            </div>
        </div>
    </div>

    @* ---------------- RIGHT: mode, fields, hints ---------------- *@
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <label class="small text-body-secondary mb-0">Template</label>
                    <select id="templateSelect" class="form-select form-select-sm">
                        @foreach (var t in Model.TemplateOptions)
                        {
                            <option value="@t.TemplateId" selected="@t.IsCurrent">@t.Label</option>
                        }
                    </select>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <label class="small text-body-secondary mb-0">Mapping mode</label>
                    <select id="modeSelect" class="form-select form-select-sm" style="max-width: 220px;">
                        <option value="OCR_FIRST">OCR-first (blocks)</option>
                        <option value="ZONAL">Zonal (drawn zones)</option>
                    </select>
                </div>
            </div>
            <div class="card-body">
                <div class="input-group input-group-sm mb-2">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input id="filter" class="form-control" placeholder="Filter…" />
                </div>
                <div id="pane-fields"></div>
            </div>
            <div class="card-footer zone-footer d-flex flex-wrap align-items-center gap-2">
                <div class="btn-group btn-group-sm zone-footer-actions" role="group">
                    <button type="button" class="btn btn-outline-primary" id="addField">
                        <i class="bi bi-plus-lg"></i> New field
                    </button>
                    <button type="button" class="btn btn-outline-primary" id="addTable">
                        <i class="bi bi-table"></i> New table
                    </button>
                </div>
                <div class="zone-footer-save d-flex align-items-center gap-2 ms-auto">
                    <span id="status" class="zone-status small text-body-secondary"></span>
                    <button type="button" class="btn btn-sm btn-primary" id="saveBtn"><i class="bi bi-save"></i> Save</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script id="zone-data" type="application/json">@Json.Serialize(data)</script>

@section Scripts {
    <script src="~/js/overlay.js" asp-append-version="true"></script>
    <script src="~/js/zone-designer.js" asp-append-version="true"></script>
}
